# NX Ignore File
# Exclude directories from NX's file watching to reduce inotify usage

# Python virtual environment (50k+ files)
apps/api/.venv

# Python cache
**/__pycache__
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Next.js build output (watched separately by Next.js)
apps/web/.next
docs/.next

# Logs
**/logs

# Other build artifacts
apps/desktop/dist
apps/desktop/out

# CLI cloned repos (from gaia init testing)
packages/cli/gaia

# Claude Code worktrees (contain duplicate project definitions)
.claude/worktrees
.conductor

# Baked Grafana image — has a Dockerfile but is not an Nx project. Without this,
# the @nx/docker plugin infers an unnamed project and the whole graph fails to
# build ("no name provided"), breaking every nx command.
infra/docker/observability/grafana/Dockerfile

