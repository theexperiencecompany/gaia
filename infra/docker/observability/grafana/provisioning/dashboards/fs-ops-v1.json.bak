          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (mode) (rate(fs_op_duration_seconds_count{operation=\"sbx_acquire\"}[5m]))",
          "legendFormat": "{{mode}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "sbx_acquire rate by mode",
