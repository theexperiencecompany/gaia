    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "p99 latency of sbx_acquire split by mode label. Cold creates and resumes should dominate; hits and hit_fast should be near zero.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
