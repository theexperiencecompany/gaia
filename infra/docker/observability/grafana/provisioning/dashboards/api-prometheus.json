      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(http_requests_total{job=\"gaia-api\"}[$__rate_interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
