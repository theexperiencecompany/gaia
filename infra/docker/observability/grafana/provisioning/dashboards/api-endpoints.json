          "expr": "quantile_over_time(0.50, {service=\"gaia-backend\"} | json | message = \"http_request\" | path =~ \"$path\" | unwrap duration_ms [5m]) by (path)",
          "interval": "5m",
          "legendFormat": "p50 {{path}}",
          "refId": "A"
