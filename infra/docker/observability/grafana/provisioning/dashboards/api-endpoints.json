          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(rate({service=\"gaia-backend\"} | json | message = \"http_request\" | path =~ \"$path\" | status_code >= 400 | status_code < 500 [$__auto]))",
          "interval": "5m",
          "legendFormat": "4xx",
          "refId": "A"
