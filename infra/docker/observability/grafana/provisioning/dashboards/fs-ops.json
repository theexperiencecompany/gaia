    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Counts of bash tool invocations in the last hour, bucketed by exit code. '0' = success. '127' = command not found. '128-254' = signal-killed. 'timeout' = killed by the tool's own deadline.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
