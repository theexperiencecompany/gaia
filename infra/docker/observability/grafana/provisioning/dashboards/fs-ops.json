  },
  "description": "FS_OPS metrics — lifetime totals, in-flight gauges, sandbox pool occupancy, percentile latencies, error rate, byte throughput, sbx_acquire mode breakdown, bash exit codes. Sourced from collectors registered in apps/api/app/services/storage/metrics.py and apps/api/app/agents/tools/coding/bash_tool.py. Designed to remain useful through normal idle periods between chat turns; rate windows are 30m and gauge-driven panels never go to 'No data' once first observed.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": ["gaia"],
      "targetBlank": false,
      "title": "GAIA Dashboards",
      "tooltip": "",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Lifetime counts per FS operation. Populated as soon as any op has fired since the process started. The 'last seen' column shows time-since-most-recent observation; quiet ops are easy to spot.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors" },
            "properties": [
              {
                "id": "thresholds",
                "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background-solid" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "last seen (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "total" }]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (operation) (fs_op_total)",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "TOTAL"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (operation) (fs_op_total{status=\"error\"}) or label_replace(vector(0), \"operation\", \"\", \"\", \"\")",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "ERRORS"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "time() - max by (operation) (fs_op_last_seen_unix_seconds)",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "LASTSEEN"
        }
      ],
      "title": "Lifetime totals (all FS operations)",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "operation", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true },
            "indexByName": {},
            "renameByName": {
              "Value #TOTAL": "total",
              "Value #ERRORS": "errors",
              "Value #LASTSEEN": "last seen (s)"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "FS operations currently executing. Each long-running mount, slow LLM-driven bash, or stuck command becomes a visible bump. Healthy steady state is near zero with brief spikes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 30, "lineInterpolation": "stepAfter", "lineWidth": 1, "showPoints": "never", "spanNulls": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "fs_op_in_flight",
          "legendFormat": "{{operation}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "In-flight ops",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Per-replica sandbox pool occupancy. 'user' = pooled per-user AsyncSandbox handles. 'warm' = pre-created paused sandboxes (zero until the warm pool capability lands).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "stepAfter", "lineWidth": 1, "showPoints": "never", "spanNulls": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sandbox_pool_size",
          "legendFormat": "{{kind}} shard {{shard}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Sandbox pool size",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 101,
      "panels": [],
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Mean operation duration over the last 30 minutes. Computed from histogram _sum/_count so it stays populated even when few observations land in the window.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineInterpolation": "linear", "lineWidth": 1, "showPoints": "never", "spanNulls": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 4,
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(fs_op_duration_seconds_sum[30m]) / clamp_min(rate(fs_op_duration_seconds_count[30m]), 1e-9)",
          "legendFormat": "{{operation}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Mean duration per op (30m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p50 (median) duration per op over the last 30 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineInterpolation": "linear", "lineWidth": 1, "showPoints": "never", "spanNulls": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "id": 5,
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le, operation) (rate(fs_op_duration_seconds_bucket[30m])))",
          "legendFormat": "{{operation}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "p50 (30m)",
      "type": "timeseries"
