          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (operation) (rate(fs_op_duration_seconds_count{status=\"error\"}[30m])) / clamp_min(sum by (operation) (rate(fs_op_duration_seconds_count[30m])), 1e-9) or vector(0)",
