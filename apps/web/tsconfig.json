{
  "compilerOptions": {
    "skipLibCheck": true,
    "disableSourceOfProjectReferenceRedirect": true,
    "disableSolutionSearching": true,
    "disableReferencedProjectLoad": true,
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/features/chat/components/*": [
        "../../libs/chat-ui/src/features/chat/components/*",
        "./src/features/chat/components/*"
      ],
      "@/types/api/*": ["../../libs/chat-ui/src/types/api/*"],
      "@/types/features/*": ["../../libs/chat-ui/src/types/features/*"],
      "@/types/shared/*": ["../../libs/chat-ui/src/types/shared/*"],
      "@/types/libraries/*": ["../../libs/chat-ui/src/types/libraries/*"],
      "@/types/notifications": ["../../libs/chat-ui/src/types/notifications"],
      "@/types/platform": ["../../libs/chat-ui/src/types/platform"],
      "@/*": ["./src/*"],
      "@/src": ["./src/*"],
      "@shared/*": ["../../libs/shared/ts/src/*"],
      "@chat-ui": ["../../libs/chat-ui/src/index.ts"],
      "@chat-ui/*": ["../../libs/chat-ui/src/*"],
      "@icons": [
        "../../node_modules/@theexperiencecompany/gaia-icons/dist/solid-rounded"
      ],
      "@react-types/shared": [
        "./node_modules/@react-types/shared/src/index.d.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    // ".next/types/**/*.ts",
    // "next-env.d.ts",
    // ".next/types/**/*.ts",
    // "next.config.mjs",
    // "video.d.ts",
    // "dist/types/**/*.ts"
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next/dev/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
