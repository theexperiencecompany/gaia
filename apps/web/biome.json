{
  "$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
  "extends": "//",
  "files": {
    "maxSize": 2097152,
    "includes": [
      "**/*.{js,jsx,ts,tsx,json,md,mdx,yml,yaml,html,css,scss,sass}",
      "!public",
      "!src/config/iconPaths.generated.ts",
      "!src/config/iconPaths.generated.json",
      "!src/**/i18n/*.json"
    ]
  },
  "linter": {
    "domains": {
      "next": "recommended"
    }
  }
}
