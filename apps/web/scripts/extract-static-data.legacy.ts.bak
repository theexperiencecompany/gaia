// @ts-nocheck — One-shot codegen, only runs against the legacy entries/*.ts
// barrel-import data modules (which have since been replaced by the runtime
// loader in alternativesData/comparisonsData/glossaryData/combosData).
// Skipping TS check so the new async signatures don't break Next.js's
// project-wide type-check pass during build.
//
/**
 * extract-static-data.ts
 *
 * One-shot codegen: read the legacy per-feature TS data modules and dump
 * each entry as JSON under apps/web/public/data/{feature}/{slug}.json plus a
 * `_slugs.json` index for generateStaticParams.
 *
 * Run:
 *   pnpm tsx scripts/extract-static-data.ts
 *
 * Note: after extraction, the runtime loaders pull directly from public/data;
 * the entries/*.ts barrel files are no longer imported and can be archived.
 */

import { mkdirSync, rmSync, writeFileSync } from "node:fs";
import { join } from "node:path";

const PUBLIC_DATA = join(process.cwd(), "public", "data");

async function dump<T extends { slug: string }>(
  feature: string,
  rows: readonly T[],
): Promise<void> {
  const dir = join(PUBLIC_DATA, feature);
  rmSync(dir, { recursive: true, force: true });
  mkdirSync(dir, { recursive: true });

  for (const row of rows) {
    writeFileSync(join(dir, `${row.slug}.json`), JSON.stringify(row));
  }
  writeFileSync(
    join(dir, "_slugs.json"),
    JSON.stringify(rows.map((r) => r.slug)),
  );
  console.log(`  ✓ ${feature}: ${rows.length} entries → ${dir}`);
}

async function main(): Promise<void> {
  console.log(`Extracting static data → ${PUBLIC_DATA}`);

  // alternatives
  const alts = await import(
    "../src/features/alternatives/data/alternativesData"
  );
  await dump("alternatives", alts.getAllAlternatives());

  // comparisons
  const cmp = await import("../src/features/comparisons/data/comparisonsData");
  await dump("comparisons", cmp.getAllComparisons());

  // glossary
  const gls = await import("../src/features/glossary/data/glossaryData");
  await dump("glossary", gls.getAllGlossaryTerms());

  // integrations / combos
  const cb = await import("../src/features/integrations/data/combosData");
  await dump("combos", cb.getAllCombos());

  console.log("\nDone.");
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
