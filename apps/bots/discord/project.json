{
  "name": "bot-discord",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "root": "apps/bots/discord",
  "sourceRoot": "apps/bots/discord/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsx watch src/index.ts",
        "cwd": "{projectRoot}"
      }
    },
    "deploy-commands": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsx src/deploy-commands.ts",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm lint",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json"]
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm lint:fix",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm format",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome format --check .",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json"]
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm type-check",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["default", "{projectRoot}/tsconfig.json", "^production"]
    }
  }
}
