# GAIA API Configuration (required for all bots)
GAIA_API_URL=http://localhost:8000
GAIA_BOT_API_KEY=your_api_key_here

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here  # Enables slash command auto-deploy
DISCORD_GUILD_ID=your_discord_guild_id_here    # Dev only: instant updates vs global (1hr)

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your_signing_secret_here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_token_here
