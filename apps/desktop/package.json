{
  "name": "@gaia/desktop",
  "description": "GAIA Desktop - Your Personal AI Assistant",
  "version": "0.3.0",
  "private": true,
  "main": "./out/main/index.mjs",
  "scripts": {
    "build": "electron-vite build",
    "clean": "rm -rf out dist release node_modules",
    "dev": "electron-vite dev",
    "dist": "pnpm build && electron-builder --publish never",
    "dist:linux": "pnpm build && electron-builder --linux --publish never",
    "dist:mac": "pnpm build && electron-builder --mac --publish never",
    "dist:win": "pnpm build && electron-builder --win --publish never",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "pack": "pnpm build && electron-builder --dir",
    "start": "electron-vite preview",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "v8-compile-cache": "^2.4.0",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^24.3.0",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  },
  "author": {
    "name": "The Experience Company",
    "email": "support@heygaia.io"
  },
  "homepage": "https://heygaia.io",
  "license": "UNLICENSED"
}
