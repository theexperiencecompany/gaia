# ============================================================================================
# IMPORTANT: DO NOT DELETE THIS FILE
# --------------------------------------------------------------------------------------------
# This `.env.example` file is required for the repository. It serves as a reference template
# showing the environment variables needed to run the project. Actual values must be provided
# via Infisical or your own `.env` file, but this file should remain in version control.
#
# For setup instructions and details on configuring environment variables, see:
# https://docs.heygaia.io/configuration/environment-variables
# ============================================================================================

# =============================
# Core
# =============================
ENV=development                      # Environment type: development, staging, production
HOST=http://localhost:8000           # Backend host URL
FRONTEND_URL=http://localhost:3000   # Frontend URL
GAIA_BACKEND_URL=http://host.docker.internal:8000  # Voice agent backend URL
DISABLE_PROFILING=true               # Disable profiling (optional)
# =============================
# Databases & Queues
# =============================
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/postgres  # pragma: allowlist secret
MONGO_DB=mongodb://localhost:27017/gaia
REDIS_URL=redis://localhost:6379
CHROMADB_HOST=localhost
CHROMADB_PORT=8080
RABBITMQ_URL=amqp://guest:guest@localhost:5672/  # pragma: allowlist secret

# =============================
# Auth
# =============================
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=

# =============================
# Bot Integration
# =============================
# Shared key between API and bot processes (min 32 chars)
# Generate with: openssl rand -hex 32
GAIA_BOT_API_KEY=

# JWT secret for bot session tokens (min 32 chars, must differ from GAIA_BOT_API_KEY)
# Generate with: openssl rand -hex 32
BOT_SESSION_TOKEN_SECRET=
# BOT_SESSION_TOKEN_EXPIRY_MINUTES=15

# Platform OAuth (enables one-click account linking via browser)
# Without these, users link accounts via bot commands instead
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
TELEGRAM_BOT_USERNAME=heygaia_bot

# Bot tokens (required for notification channel adapters in the API)
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
KAPSO_WEBHOOK_SECRET=
WHATSAPP_PHONE_NUMBER=

# =============================
# GitHub Integration (optional)
# =============================
# Get a token at https://github.com/settings/tokens (no scopes needed)
# Provides 5,000 API requests/hour vs 60/hour without token
# Used for discovering and installing skills from GitHub
GITHUB_TOKEN=

# Infisical (optional)
# =============================
# Infisical is a secrets management platform that can centrally manage your env vars
# INFISICAL_PROJECT_ID=
# INFISICAL_MACHINE_IDENTITY_CLIENT_ID=
# INFISICAL_MACHINE_IDENTITY_CLIENT_SECRET=

# =============================
# LangSmith (optional)
# =============================
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=

# =============================
# Langfuse — LLM observability (optional, self-hosted)
# =============================
# Opt-in: traces only ship when all three are set.
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# =============================
# OpenUI (generative UI rendering)
# =============================
ENABLE_OPENUI=false

# =============================
# Coding sandbox (E2B + Cloudflare R2 + JuiceFS)
# =============================
# Required for the bash/read/write/edit tools. Leave unset to keep the coding
# tools registered-but-disabled — they return a clear "sandbox not configured"
# error at call time.

# E2B sandbox template ID — produced by:
#   uv run python apps/api/scripts/build_e2b_template.py
# E2B_TEMPLATE_ID=

# Cloudflare R2 — bucket + S3-compatible credentials.
# Create at: Cloudflare dashboard → R2 → Manage R2 API Tokens → Create.
# Copy "Access Key ID" + "Secret Access Key" from the final dialog.
# R2_ACCOUNT_ID=
# R2_BUCKET=gaia-workspaces
# R2_ACCESS_KEY=
# R2_SECRET_KEY=

# JuiceFS metadata URL — `{shard}` substituted at mount time. Dev default
# below points at the docker-compose postgres + the gaia_juicefs_0 DB created
# by infra/docker/postgres-init/10-juicefs.sql on first boot.
# JUICEFS_META_URL_TEMPLATE=postgres://postgres:postgres@postgres:5432/gaia_juicefs_{shard}?sslmode=disable

# Optional client-side RSA-4096 PEM. If set, the entrypoint writes it to
# /etc/gaia/jfs-master.pem and passes --encrypt-rsa-key to JuiceFS. Whole
# multi-line PEM stored as a single secret. Generate with:
#   openssl genrsa -out jfs-master.pem 4096
# JFS_ENCRYPTION_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Number of JuiceFS shards (Phase 1: 1, Phase 2: 16)
# JUICEFS_NUM_SHARDS=1

# =============================
# Notes
# =============================
# - Platform bot tokens (DISCORD_BOT_TOKEN, SLACK_BOT_TOKEN, TELEGRAM_BOT_TOKEN)
#   are used by both the API (notification channel adapters) and apps/bots/.env.
# - Missing optional keys disable those features gracefully.
# - For production required keys, see ProductionSettings in app/config/settings.py
# - Most API keys should be stored in Infisical or your own .env file, not committed to version control.
# - For voice agent configuration, see: https://docs.heygaia.io/configuration/voice-agent
# - For more details, see: https://docs.heygaia.io/configuration/environment-variables
