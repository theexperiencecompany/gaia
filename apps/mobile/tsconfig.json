{
  "extends": ["expo/tsconfig.base", "../../tsconfig.base.json"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"],
      "@icons": ["./src/lib/gaia-icons.tsx"],
      "@gaia/shared": ["../../libs/shared/ts/src/index.ts"],
      "@gaia/shared/*": ["../../libs/shared/ts/src/*"],
      "@shared/*": ["../../libs/shared/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/uniwind-types.d.ts"
  ]
}
