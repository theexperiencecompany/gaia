{
  "$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
  "extends": "//",
  "files": {
    "includes": ["**/*.{js,jsx,ts,tsx,json,css}", "!.expo"]
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noUnknownAtRules": "off",
        "noDuplicateCustomProperties": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "src/features/chat/components/chat/voice-recorder.tsx",
        "src/features/chat/components/tool-cards/chart-card.tsx",
        "src/features/chat/components/tool-cards/code-execution-card.tsx",
        "src/features/search/components/SearchResultItem.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noArrayIndexKey": "off"
          }
        }
      }
    }
  ]
}
