{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "apps/web": {
      "entry": [
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/route.ts",
        "src/components/mdx-components.tsx",
        "next.config.mjs"
      ],
      "paths": {
        "@icons": ["src/components/shared/icons.tsx"]
      },
      "ignoreDependencies": [
        "@icons",
        "@heroui/*",
        "@biomejs/biome",
        "@mdx-js/loader",
        "@mdx-js/react",
        "@react-types/shared",
        "@tiptap/core",
        "@tiptap/pm",
        "barrelsby",
        "depcheck",
        "glob",
        "sharp"
      ],
      "ignore": ["src/components/ui/**"]
    },
    "apps/desktop": {
      "entry": [
        "src/main/**/*.ts",
        "src/preload/**/*.ts",
        "src/renderer/**/*.ts",
        "electron.vite.config.ts"
      ],
      "ignoreDependencies": [
        "@biomejs/biome",
        "@types/wait-on",
        "electron-builder",
        "electron-vite",
        "vite"
      ]
    },
    "apps/mobile": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"],
      "ignore": ["src/**/__tests__/**"]
    },
    "apps/bots/discord": {
      "entry": ["src/bot.ts"]
    },
    "apps/bots/slack": {
      "entry": ["src/app.ts"]
    },
    "apps/bots/telegram": {
      "entry": ["src/bot.ts"]
    },
    "libs/shared/ts": {
      "entry": ["src/index.ts", "src/**/index.ts"]
    }
  },
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "**/*.d.ts",
    "**/vitest.config.*",
    "**/jest.config.*",
    "apps/bots/vitest.config.ts",
    "**/__tests__/**",
    ".agents/**",
    ".claude/**",
    "apps/web/content/**",
    "apps/web/scripts/**",
    "apps/web/src/config/iconPaths.generated.ts"
  ],
  "ignoreDependencies": ["nx", "@nx/*"],
  "ignoreBinaries": [
    "uv",
    "uvx",
    "vitest",
    "build",
    "dev",
    "dist",
    "dist:mac",
    "dist:win",
    "dist:linux",
    "type-check",
    "lint",
    "lint:fix",
    "pack",
    "tsc",
    "tsx",
    "electron-vite",
    "electron-builder",
    "biome",
    "clean",
    "nx",
    "check",
    "fix",
    "format",
    "type",
    "depcheck",
    "barrelsby"
  ],
  "exclude": ["unlisted"]
}
