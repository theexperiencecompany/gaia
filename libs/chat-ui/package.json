{
  "name": "@heygaia/chat-ui",
  "version": "0.0.0",
  "description": "GAIA chat UI components — extracted from gaia/apps/web for reuse across surfaces (web app, motion studio, demos).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "type-check": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/theexperiencecompany/gaia.git",
    "directory": "libs/chat-ui"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "next": ">=15",
    "@heroui/accordion": "*",
    "@heroui/button": "*",
    "@heroui/chip": "*",
    "@heroui/skeleton": "*",
    "@heroui/spinner": "*",
    "@heroui/tooltip": "*",
    "@theexperiencecompany/gaia-icons": "^1.9.0",
    "class-variance-authority": "*",
    "clsx": "*",
    "date-fns": "*",
    "tailwind-merge": "*",
    "motion": "*",
    "react-markdown": "*",
    "remark-gfm": "*",
    "zustand": "*"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@heroui/accordion": "^2.2.21",
    "@heroui/button": "^2.2.27",
    "@heroui/chip": "^2.2.22",
    "@heroui/skeleton": "^2.2.18",
    "@heroui/spinner": "^2.2.20",
    "@heroui/tooltip": "^2.2.22",
    "@theexperiencecompany/gaia-icons": "^1.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "motion": "^12.0.0",
    "next": "^16.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    "date-fns": "^3.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "zustand": "^5.0.0"
  }
}
