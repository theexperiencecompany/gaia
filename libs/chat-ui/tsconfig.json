{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@/types/features/*": ["src/types/features/*"],
      "@/types/shared/*": ["src/types/shared/*"],
      "@/types/api/*": ["src/types/api/*"],
      "@/types/*": ["src/types/*"],
      "@/config/registries/*": ["src/config/registries/*"],
      "@/config/openui/*": ["src/stubs/config/openui/*"],
      "@/config/openui": ["src/stubs/config/openui/index"],
      "@/config/toolIconConfig": ["src/config/toolIconConfig"],
      "@/config/*": ["src/config/*"],
      "@/features/chat/components/*": ["src/features/chat/components/*"],
      "@/features/chat/utils/*": ["src/features/chat/utils/*"],
      "@/features/chat/api/*": ["src/stubs/features/chat/api/*"],
      "@/features/chat/hooks/*": ["src/stubs/features/chat/hooks/*"],
      "@/features/chat/actions/*": ["src/stubs/features/chat/actions/*"],
      "@/features/auth/*": ["src/stubs/features/auth/*"],
      "@/features/calendar/*": ["src/features/calendar/*"],
      "@/features/mail/*": ["src/features/mail/*"],
      "@/features/weather/*": ["src/features/weather/*"],
      "@/features/workflows/*": ["src/features/workflows/*"],
      "@/features/integrations/*": ["src/features/integrations/*"],
      "@/features/reddit/*": ["src/features/reddit/*"],
      "@/features/twitter/*": ["src/features/twitter/*"],
      "@/features/todo/*": ["src/features/todo/*"],
      "@/features/notification/*": ["src/features/notification/*"],
      "@/features/support/*": ["src/features/support/*"],
      "@/features/use-cases/*": ["src/features/use-cases/*"],
      "@/features/memory/*": ["src/features/memory/*"],
      "@/components/shared/*": ["src/components/shared/*"],
      "@/components/ui/*": ["src/components/ui/*"],
      "@/utils/calendar/*": ["src/utils/calendar/*"],
      "@/utils/date/*": ["src/utils/date/*"],
      "@/utils/*": ["src/utils/*"],
      "@/hooks/*": ["src/hooks/*"],
      "@/stores/*": ["src/stubs/stores/*"],
      "@/lib/db/*": ["src/stubs/lib/db/*"],
      "@/lib/db": ["src/stubs/lib/db/index"],
      "@/lib/api/*": ["src/stubs/lib/api/*"],
      "@/lib/toast": ["src/stubs/lib/toast"],
      "@/lib/analytics": ["src/stubs/lib/analytics"],
      "@/lib/utils": ["src/stubs/lib/utils"],
      "@/lib/*": ["src/stubs/lib/*"],
      "@/services/*": ["src/stubs/services/*"],
      "@/i18n/*": ["src/stubs/i18n/*"],
      "@shared/utils/*": ["src/shared/utils/*"],
      "@shared/utils": ["src/shared/utils/index"],
      "@shared/types/*": ["src/shared/types/*"],
      "@shared/types": ["src/shared/types/index"],
      "@shared/api/*": ["src/shared/api/*"],
      "@shared/api": ["src/shared/api/index"],
      "@shared/icons/*": ["src/shared/icons/*"],
      "@shared/icons": ["src/shared/icons/index"],
      "@shared/tool-utils/*": ["src/shared/tool-utils/*"],
      "@shared/tool-utils": ["src/shared/tool-utils/index"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
