{
  "name": "@gaia/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript utilities for GAIA applications",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./bots": "./src/bots/index.ts",
    "./chat": "./src/chat/index.ts",
    "./cli": "./src/cli/index.ts",
    "./icons": "./src/icons/index.ts",
    "./tool-utils": "./src/tool-utils/index.ts",
    "./utils": "./src/utils/index.ts",
    "./types": "./src/types/index.ts",
    "./api": "./src/api/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@infisical/sdk": "^4.0.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "string-similarity": "^4.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/string-similarity": "^4.0.2",
    "typescript": "^5.7.0"
  }
}
