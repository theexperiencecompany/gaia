    "./cli": "./src/cli/index.ts",
    "./icons": "./src/icons/index.ts",
    "./tool-utils": "./src/tool-utils/index.ts",
    "./utils": "./src/utils/index.ts",
    "./types": "./src/types/index.ts",
    "./types/files": "./src/types/files.ts",
    "./types/integrations": "./src/types/integrations.ts",
    "./types/search": "./src/types/search.ts",
    "./types/reminders": "./src/types/reminders.ts",
    "./types/skills": "./src/types/skills.ts",
    "./types/tools": "./src/types/tools.ts",
    "./types/notes": "./src/types/notes.ts",
    "./types/memory": "./src/types/memory.ts",
    "./types/chat": "./src/types/chat.ts",
    "./types/models": "./src/types/models.ts",
    "./api": "./src/api/index.ts",
