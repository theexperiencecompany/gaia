  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/node": "^24.3.0",
    "@types/string-similarity": "^4.0.2",
    "typescript": "^5.9.3",
    "zustand": "^5.0.9"
  },
  "peerDependencies": {
    "zustand": "^5.0.9"
