{
  "name": "shared-typescript",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "root": "libs/shared/ts",
  "sourceRoot": "libs/shared/ts/src",
  "projectType": "library",
  "tags": ["scope:typescript"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check .",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json"]
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check --write .",
        "cwd": "{projectRoot}"
      },
      "cache": false
    }
  }
}
