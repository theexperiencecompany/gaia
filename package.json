{
  "name": "gaia",
  "scripts": {
    "tokens:export": "design.md export --format dtcg DESIGN.md > design.tokens.json",
    "tokens:build": "style-dictionary build",
    "tokens": "pnpm run tokens:export && pnpm run tokens:build",
    "tokens:check": "design.md export --format dtcg DESIGN.md | diff - design.tokens.json",
    "quality:lint": "biome check",
    "quality:lint:fix": "biome check --write",
    "quality:format": "biome format --write",
    "quality:type": "nx run-many -t type-check",
    "quality:deps": "syncpack lint && manypkg check",
    "quality:deps:fix": "syncpack fix && manypkg fix",
    "quality:dead": "bash scripts/dead-code-check.sh",
    "quality:dead:strict": "bash scripts/dead-code-check.sh --strict",
    "quality:circular": "madge --circular --extensions ts,tsx apps/web/src apps/mobile/src apps/desktop/src apps/bots libs/shared/ts/src packages/cli/src",
    "quality:dupe": "jscpd --silent",
    "quality:size": "node scripts/ci/check-file-sizes.mjs",
    "quality:components": "node scripts/ci/check-components-per-file.mjs",
    "quality:types-location": "node scripts/ci/check-types-location.mjs",
    "quality:pkg-json": "npmPkgJsonLint . --quiet",
    "quality:type-coverage": "type-coverage --project apps/web/tsconfig.json --at-least 85 --ignore-catch --ignore-unread",
    "quality:all": "pnpm run quality:lint && pnpm run quality:type && pnpm run quality:deps && pnpm run quality:circular && pnpm run quality:size && pnpm run quality:components && pnpm run quality:types-location && pnpm run quality:pkg-json && pnpm run quality:dead"
  },
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@google/design.md": "^0.1.1",
    "@manypkg/cli": "^0.25.1",
    "@nx/docker": "^22.2.3",
    "@nx/next": "^22.2.3",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.8.6",
    "@swc/core": "^1.15.13",
    "@swc/helpers": "^0.5.19",
    "dpdm": "^4.2.0",
    "jscpd": "^4.2.2",
    "knip": "^5",
    "madge": "^8.0.0",
    "next": "16.1.7",
    "npm-package-json-lint": "^10.4.0",
    "nx": "^22.2.3",
    "publint": "^0.3.21",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "style-dictionary": "^4.4.0",
    "syncpack": "^15.1.2",
    "tsx": "^4.21.0",
    "type-coverage": "^2.29.7"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@heroui/shared-utils"
    ],
    "onlyBuiltDependencies": [
      "@heroui/shared-utils",
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "canvas",
      "core-js",
      "electron",
      "esbuild",
      "nx",
      "protobufjs",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "zod": "4.3.6",
      "fast-xml-parser@<4.5.5": "4.5.5",
      "fast-xml-parser@>=5.0.0 <5.5.7": "5.5.7",
      "node-forge@<1.4.0": "1.4.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=8.0.0 <8.0.6": "8.0.6",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "undici@>=6.0.0 <6.24.0": "6.24.0",
      "undici@>=7.0.0 <7.24.0": "7.24.0",
      "flatted@<3.4.2": "3.4.2",
      "axios@<1.13.5": "1.13.5",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "preact@<10.28.2": "10.28.2",
      "serialize-javascript@<7.0.5": "7.0.5",
      "trim-newlines@<3.0.1": "3.0.1",
      "hono@<4.12.12": "4.12.12",
      "immutable@>=5.0.0 <5.1.5": "5.1.5",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "express-rate-limit@>=8.0.0 <8.2.2": "8.2.2",
      "@xmldom/xmldom@<0.8.12": "0.8.12",
      "simple-git@<3.32.3": "3.32.3",
      "tar@<7.5.11": "7.5.11",
      "koa@>=3.0.0 <3.1.2": "3.1.2",
      "lodash-es@<=4.17.23": "4.18.0",
      "prismjs@<1.30.0": "1.30.0",
      "esbuild@<=0.24.2": "0.25.0",
      "@smithy/config-resolver@<4.4.0": "4.4.0",
      "@tootallnate/once@<3.0.1": "3.0.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react-remove-scroll>@types/react": "^19.0.0"
      }
    }
  }
}
