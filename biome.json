{
  "$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "ignoreUnknown": true,
    "maxSize": 2097152,
    "includes": [
      "**/*.{js,jsx,ts,tsx,json,md,mdx,yml,yaml,html,css,scss,sass}",
      "!!apps/web/public",
      "!!**/node_modules",
      "!!**/.next",
      "!!**/dist",
      "!!**/out",
      "!!**/.vercel",
      "!!**/.venv",
      "!!**/.venv311",
      "!!**/__pycache__",
      "!!**/.mypy_cache",
      "!!**/.ruff_cache",
      "!!**/.pytest_cache",
      "!!**/.nx",
      "!!**/.turbo",
      "!!**/coverage",
      "!!apps/api",
      "!!apps/voice-agent",
      "!!infra",
      "!!docs",
      "!!.claude",
      "!!.agents",
      "!!.husky",
      "!!.yarn",
      "!!.vscode",
      "!!.idea",
      "!!.github",
      "!!.mise",
      "!!.opencode",
      "!!.worktrees",
      "!!.jscpd-report",
      "!**/pnpm-lock.yaml",
      "!**/*.lock",
      "!**/.env*",
      "!**/*.d.ts",
      "!**/tsconfig.tsbuildinfo",
      "!**/*.log",
      "!**/.DS_Store",
      "!**/*.generated.ts",
      "!**/*.generated.json",
      "!apps/web/src/**/i18n/*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "attributePosition": "auto",
    "bracketSameLine": false,
    "bracketSpacing": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "useKeyWithMouseEvents": "off"
      },
      "complexity": {
        "noBannedTypes": "error",
        "noForEach": "off",
        "noStaticOnlyClass": "off",
        "noUselessEmptyExport": "off",
        "useLiteralKeys": "off",
        "noUselessFragments": "error",
        "noUselessTypeConstraint": "error",
        "noUselessLoneBlockStatements": "error",
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 25 }
        }
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedPrivateClassMembers": "error",
        "noUnusedLabels": "error",
        "useExhaustiveDependencies": "off",
        "useHookAtTopLevel": "error"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "error",
        "useNodejsImportProtocol": "off",
        "noParameterAssign": "off",
        "noNamespace": "error",
        "useConsistentArrayType": {
          "level": "error",
          "options": { "syntax": "shorthand" }
        },
        "useShorthandFunctionType": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "error",
        "noExplicitAny": "error",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["error", "warn", "info", "debug"] }
        },
        "useIterableCallbackReturn": "off",
        "noEmptyBlockStatements": "warn",
        "noEvolvingTypes": "error",
        "noDebugger": "error",
        "noShadowRestrictedNames": "error",
        "noSparseArray": "error",
        "noUnsafeDeclarationMerging": "error",
        "noVar": "error",
        "useDefaultSwitchClauseLast": "error",
        "noMisleadingInstantiator": "error",
        "noMisrefactoredShorthandAssign": "error"
      },
      "performance": {
        "noBarrelFile": "off",
        "noReExportAll": "warn",
        "noAccumulatingSpread": "error",
        "noDelete": "error"
      },
      "security": {
        "noDangerouslySetInnerHtmlWithChildren": "error",
        "noGlobalEval": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "quoteStyle": "double",
      "attributePosition": "auto"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "plugins": [
    "./config/biome-rules/no-direct-gaia-icons-import.grit",
    "./config/biome-rules/no-chevron-from-icons.grit",
    "./config/biome-rules/no-hugeicons-import.grit",
    "./config/biome-rules/no-motion-react-heavy-imports.grit",
    "./config/biome-rules/no-motion-full-import.grit"
  ],
  "overrides": [
    {
      "includes": ["apps/web/**"],
      "linter": {
        "domains": {
          "next": "recommended"
        }
      }
    },
    {
      "includes": [
        "apps/web/src/features/**/index.ts",
        "apps/web/src/features/**/index.tsx",
        "apps/web/src/app/**/index.ts",
        "apps/web/src/app/**/index.tsx"
      ],
      "plugins": ["./config/biome-rules/no-barrel-reexport.grit"]
    },
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/__tests__/**",
        "**/__mocks__/**",
        "**/*.stories.tsx",
        "**/*.config.{ts,js,mjs,cjs}",
        "**/scripts/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off",
            "noExplicitAny": "warn"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off"
          },
          "performance": {
            "noReExportAll": "off"
          }
        }
      }
    },
    {
      "includes": ["**/types.ts", "**/types/**", "**/*.types.ts", "**/*.d.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noReExportAll": "off"
          },
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
