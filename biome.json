{
  "$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "ignoreUnknown": true,
    "maxSize": 2097152,
    "includes": [
      "**/*.{js,jsx,ts,tsx,json,md,mdx,yml,yaml,html,css,scss,sass}",
      "!!apps/web/public",
      "!!**/node_modules",
      "!!**/.next",
      "!!**/dist",
      "!!**/out",
      "!!**/.vercel",
      "!!**/.venv",
      "!!**/.venv311",
      "!!**/__pycache__",
      "!!**/.mypy_cache",
      "!!**/.ruff_cache",
      "!!**/.pytest_cache",
      "!!**/.nx",
      "!!**/.turbo",
      "!!**/coverage",
      "!!apps/api",
      "!!apps/voice-agent",
      "!!infra",
      "!!docs",
      "!!.claude",
      "!!.agents",
      "!!.husky",
      "!!.yarn",
      "!!.vscode",
      "!!.idea",
      "!!.github",
      "!!.mise",
      "!!.opencode",
      "!!.worktrees",
      "!**/pnpm-lock.yaml",
      "!**/*.lock",
      "!**/.env*",
      "!**/*.d.ts",
      "!**/tsconfig.tsbuildinfo",
      "!**/*.log",
      "!**/.DS_Store",
      "!**/*.generated.ts",
      "!**/*.generated.json",
      "!apps/web/src/**/i18n/*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "attributePosition": "auto",
    "bracketSameLine": false,
    "bracketSpacing": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "useKeyWithMouseEvents": "off"
      },
      "complexity": {
        "noBannedTypes": "off",
        "noForEach": "off",
        "noStaticOnlyClass": "off",
        "noUselessEmptyExport": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "useExhaustiveDependencies": "off",
        "useHookAtTopLevel": "error"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "warn",
        "useNodejsImportProtocol": "off",
        "noParameterAssign": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "error",
        "noExplicitAny": "error",
        "noConsole": "off",
        "useIterableCallbackReturn": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "quoteStyle": "double",
      "attributePosition": "auto"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "plugins": [
    "./rules/no-direct-gaia-icons-import.grit",
    "./rules/no-chevron-from-icons.grit",
    "./rules/no-hugeicons-import.grit",
    "./rules/no-motion-react-heavy-imports.grit",
    "./rules/no-motion-full-import.grit"
  ],
  "overrides": [
    {
      "includes": ["apps/web/**"],
      "linter": {
        "domains": {
          "next": "recommended"
        }
      }
    },
    {
      "includes": [
        "apps/web/src/features/**/index.ts",
        "apps/web/src/features/**/index.tsx",
        "apps/web/src/app/**/index.ts",
        "apps/web/src/app/**/index.tsx"
      ],
      "plugins": ["./rules/no-barrel-reexport.grit"]
    }
  ]
}
