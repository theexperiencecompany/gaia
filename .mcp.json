        "PATH": "/Users/dhruvmaradiya/Library/Android/sdk/platform-tools:/Users/dhruvmaradiya/Library/Android/sdk/emulator:/Users/dhruvmaradiya/.local/share/mise/installs/java/21.0.2/bin:/usr/local/bin:/usr/bin:/bin"
      }
