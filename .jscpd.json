{
  "threshold": 3.5,
  "reporters": ["consoleFull", "json"],
  "output": ".jscpd-report",
  "absolute": true,
  "gitignore": true,
  "minTokens": 80,
  "minLines": 10,
  "maxLines": 2000,
  "maxSize": "120kb",
  "format": ["javascript", "typescript", "tsx", "jsx"],
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/.nx/**",
    "**/.turbo/**",
    "**/dist/**",
    "**/out/**",
    "**/build/**",
    "**/coverage/**",
    "**/.venv/**",
    "**/.venv311/**",
    "**/__pycache__/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/.pytest_cache/**",
    "**/__tests__/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.d.ts",
    "**/*.generated.*",
    "**/i18n/*.json",
    "apps/web/public/**",
    "apps/web/content/**",
    "apps/api/**",
    "apps/voice-agent/**",
    "infra/**",
    "docs/**",
    ".agents/**",
    ".claude/**",
    ".github/**",
    "rules/**"
  ]
}
